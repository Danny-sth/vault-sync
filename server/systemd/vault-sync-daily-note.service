[Unit]
Description=Create Obsidian Daily Note
After=vault-sync.service
Wants=vault-sync.service

[Service]
Type=oneshot
User=root
Environment="VAULT_SYNC_STORAGE=/opt/obsidian-vault"
ExecStart=/opt/vault-sync/scripts/create-daily-note.sh
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
